{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Library System",
      "request": "launch",
      "mainClass": "library_system.Main",
      "cwd": "${workspaceFolder}",
      "classPaths": [
        "${workspaceFolder}/bin",
        "${workspaceFolder}/lib/mysql-connector-j-9.7.0.jar"
      ],
      "preLaunchTask": "build project"
    },
    {
      "type": "java",
      "name": "Test Database Connection",
      "request": "launch",
      "mainClass": "library_system.TestConnection",
      "cwd": "${workspaceFolder}",
      "classPaths": [
        "${workspaceFolder}/bin",
        "${workspaceFolder}/lib/mysql-connector-j-9.7.0.jar"
      ],
      "preLaunchTask": "build project"
    }
  ]
}